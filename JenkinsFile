pipeline {
    agent any

    environment {
        PATH = "$HOME/bin:$PATH"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Aryan-Dot-Dev/Devops_Assignment.git',
                    branch: "${env.BRANCH_NAME}"
            }
        }

        stage('Install Bun') {
            steps {
                sh '''
                mkdir -p $HOME/bin

                curl -L https://github.com/oven-sh/bun/releases/latest/download/bun-linux-x64.zip -o bun.zip
                unzip -o bun.zip

                mv bun-linux-x64/bun $HOME/bin/bun
                chmod +x $HOME/bin/bun

                bun --version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd app
                bun install
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                sh '''
                cd app
                bun test ../tests/unit
                '''
            }
        }

        stage('Integration Tests') {
            steps {
                sh '''
                cd app

                # Start Auth Service in background
                bun run auth/index.ts > /tmp/auth.log 2>&1 &
                AUTH_PID=$!
                echo "Auth service started with PID: $AUTH_PID"
                sleep 2

                # Start User Service in background
                bun run index.ts > /tmp/user.log 2>&1 &
                USER_PID=$!
                echo "User service started with PID: $USER_PID"
                sleep 2

                # Run integration tests
                bun test ../tests/integration || TEST_RESULT=$?

                # Cleanup services
                kill $AUTH_PID $USER_PID 2>/dev/null || true
                wait $AUTH_PID $USER_PID 2>/dev/null || true

                # Exit with test result
                exit ${TEST_RESULT:-0}
                '''
            }
        }

        stage('Build Auth Image') {
            steps {
                sh 'docker build -t suspiciousdude/auth-service:latest -f DockerFile.auth .'
            }
        }

        stage('Build User Image') {
            steps {
                sh 'docker build -t suspiciousdude/user-service:latest -f DockerFile.user .'
            }
        }


        stage('Docker Login') {
             steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    '''
                }
            }
        }
        stage('Push Auth Image') {
            steps {
                sh 'docker push suspiciousdude/auth-service:latest'
            }
        }

        stage('Push User Image') {
            steps {
                sh 'docker push suspiciousdude/user-service:latest'
            }
        }

        stage('Deploy Microservices') {
            steps {
                sh '''
                kubectl apply -f k8s/auth-deployment.yaml
                kubectl apply -f k8s/auth-service.yaml
                kubectl apply -f k8s/user-deployment.yaml
                kubectl apply -f k8s/user-service.yaml
                '''
            }
        }
    }
}