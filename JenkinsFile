pipeline {
    agent any
    tools {
        nodejs 'NodeJS'
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'master', url: 'https://github.com/Aryan-Dot-Dev/Devops_Assignment.git'
            }
        }

        stage('Unit Tests') {
            steps {
                sh 'cd app && bun test tests/unit'
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'cd app && bun test tests/integration'
            }
        }
    }
}