pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Aryan-Dot-Dev/Devops_Assignment.git',
                    branch: "${env.BRANCH_NAME}"
            }
        }

        stage('Install Bun') {
            steps {
                sh '''
                apt-get update
                apt-get install -y unzip curl

                curl -L https://github.com/oven-sh/bun/releases/latest/download/bun-linux-x64.zip -o bun.zip
                unzip bun.zip
                mv bun-linux-x64/bun /usr/local/bin/bun
                chmod +x /usr/local/bin/bun

                bun --version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                export PATH="$HOME/.bun/bin:$PATH"
                cd app
                bun install
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                sh 'cd app && bun test tests/unit'
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'cd app && bun test tests/integration'
            }
        }
    }
}