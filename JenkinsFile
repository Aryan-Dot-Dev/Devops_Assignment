pipeline {
    agent any

    environment {
        PATH = "$HOME/bin:$PATH"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Aryan-Dot-Dev/Devops_Assignment.git',
                    branch: "${env.BRANCH_NAME}"
            }
        }

        stage('Install Bun') {
            steps {
                sh '''
                mkdir -p $HOME/bin

                curl -L https://github.com/oven-sh/bun/releases/latest/download/bun-linux-x64.zip -o bun.zip
                unzip -o bun.zip

                mv bun-linux-x64/bun $HOME/bin/bun
                chmod +x $HOME/bin/bun

                bun --version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd app
                bun install
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                sh '''
                bun test tests/unit
                '''
            }
        }

        stage('Integration Tests') {
            steps {
                sh '''
                bun test tests/integration
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker build -t suspiciousdude/final-devops:latest .
                '''
            }
        }

        stage('Docker Login') {
             steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    '''
                }
            }
        }

        stage('Docker Push') {
            steps {
                sh '''
                    docker push suspiciousdude/final-devops:latest
                '''
            }
        }
    }
}