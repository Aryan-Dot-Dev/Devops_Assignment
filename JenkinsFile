pipeline {
    agent any

    environment {
        PATH = "$HOME/bin:$PATH"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Aryan-Dot-Dev/Devops_Assignment.git',
                    branch: "${env.BRANCH_NAME}"
            }
        }

        stage('Install Bun') {
            steps {
                sh '''
                mkdir -p $HOME/bin

                curl -L https://github.com/oven-sh/bun/releases/latest/download/bun-linux-x64.zip -o bun.zip
                unzip -o bun.zip

                mv bun-linux-x64/bun $HOME/bin/bun
                chmod +x $HOME/bin/bun

                bun --version
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd app
                bun install
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                sh '''
                bun test tests/unit
                '''
            }
        }

        stage('Integration Tests') {
            steps {
                sh '''
                bun test tests/integration
                '''
            }
        }

        stage('Build Auth Image') {
            steps {
                sh 'docker build -t suspiciousdude/auth-service:latest -f DockerFile.auth .'
            }
        }

        stage('Build User Image') {
            steps {
                sh 'docker build -t suspiciousdude/user-service:latest -f DockerFile.user .'
            }
        }


        stage('Docker Login') {
             steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    '''
                }
            }
        }

        stage('Build User Image') {
            steps {
                sh 'docker build -t suspiciousdude/user-service:latest -f DockerFile.user .'
            }
        }

        stage('Push User Image') {
            steps {
                sh 'docker push suspiciousdude/user-service:latest'
            }
        }

        stage('Deploy Blue (initial)') {
            steps {
                sh '''
                    kubectl apply -f k8s/deployment-blue.yaml
                    kubectl apply -f k8s/service.yaml
                '''
            }
        }

        stage('Deploy Green') {
            steps {
                sh 'kubectl apply -f k8s/deployment-green.yaml'
            }
        }

        stage('Switch to Green') {
            steps {
                sh '''
                kubectl patch service app-service -p '{
                "spec": {
                    "selector": {
                    "app": "myapp",
                    "version": "green"
                    }
                }
                }'
                '''
            }
        }

        stage('Deploy Microservices') {
            steps {
                sh '''
                kubectl apply -f k8s/auth-deployment.yaml
                kubectl apply -f k8s/auth-service.yaml
                kubectl apply -f k8s/user-deployment.yaml
                kubectl apply -f k8s/user-service.yaml
                '''
            }
        }
    }

    post {
        failure {
            sh '''
            kubectl patch service app-service -p '{
            "spec": {
                "selector": {
                "app": "myapp",
                "version": "blue"
                }
            }
            }'
            '''
        }
    }
}