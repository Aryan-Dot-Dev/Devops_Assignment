{
  "name": "app",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --watch index.ts",
    "start:auth": "bun run auth/index.ts",
    "dev:auth": "bun --watch auth/index.ts",
    "start:all": "concurrently \"bun run start\" \"bun run start:auth\"",
    "dev:all": "concurrently \"bun run dev\" \"bun run dev:auth\"",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test": "bun test"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^8.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
